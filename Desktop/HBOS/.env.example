# ============================================================================
# HBOS Environment Variables
# Copy this file to .env.local and update with actual values
# ============================================================================

# Node Environment
NODE_ENV=development

# ============================================================================
# DATABASE
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=hbos
DB_PASSWORD=hbos_dev_password
DB_NAME=hbos_development

# Database Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================================================
# REDIS
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================================
# BACKEND API
# ============================================================================
API_PORT=3001
API_HOST=localhost
API_BASE_URL=http://localhost:3001

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=900 # 15 minutes
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRY=604800 # 7 days

# ============================================================================
# FRONTEND
# ============================================================================
FRONTEND_PORT=3000
FRONTEND_HOST=localhost
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ============================================================================
# EMAIL & NOTIFICATIONS
# ============================================================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@hbos.io

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================================================
# PAYMENT PROCESSING
# ============================================================================
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================================
# FILE STORAGE
# ============================================================================
S3_REGION=us-east-1
S3_BUCKET=hbos-dev-bucket
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT= # For MinIO or custom S3-compatible storage

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
SENTRY_DSN=
LOG_LEVEL=debug

# ============================================================================
# SECURITY
# ============================================================================
# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false # true in production with HTTPS

# ============================================================================
# THIRD-PARTY SERVICES
# ============================================================================
# Google OAuth (optional, Phase 2+)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional, Phase 2+)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================================
# OPENAI / LLM (Phase 4)
# ============================================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Claude API (Alternative)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus

# ============================================================================
# ANALYTICS & TRACKING (Phase 4)
# ============================================================================
SEGMENT_WRITE_KEY=

# ============================================================================
# ADMIN & MAINTENANCE
# ============================================================================
# Super admin email (for initial setup)
ADMIN_EMAIL=admin@hbos.io
ADMIN_PASSWORD=

# Debug mode
DEBUG=hbos:*

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_HOTEL_MANAGEMENT=false
FEATURE_AI_ASSISTANT=false
FEATURE_WORKFLOW_AUTOMATION=false
FEATURE_MOBILE_APP=false
