{
  "name": "@hbos/backend",
  "version": "0.0.1",
  "description": "HBOS Backend - NestJS API server",
  "author": "HBOS Team",
  "private": true,
  "license": "PROPRIETARY",
  "scripts": {
    "dev": "nest start --watch",
    "debug": "nest start --debug --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "db:migrate": "typeorm migration:run -d src/database/typeorm.config.ts",
    "db:migrate:create": "typeorm migration:create",
    "db:rollback": "typeorm migration:revert -d src/database/typeorm.config.ts",
    "db:seed": "ts-node src/database/seeds/seed.ts",
    "db:generate": "typeorm migration:generate",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "@hbos/core": "workspace:*",
    "@nestjs/common": "^10.2.10",
    "@nestjs/core": "^10.2.10",
    "@nestjs/platform-express": "^10.2.10",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^10.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "@nestjs/typeorm": "^9.0.1",
    "typeorm": "^0.3.17",
    "pg": "^8.11.3",
    "redis": "^4.6.11",
    "@nestjs/swagger": "^7.1.10",
    "swagger-ui-express": "^5.0.0",
    "@nestjs/schedule": "^4.0.1",
    "bull": "^4.11.4",
    "@nestjs/bull": "^10.0.1",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "helmet": "^7.1.0",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.0",
    "@types/passport-jwt": "^3.0.11",
    "@nestjs/cli": "^10.2.1",
    "@nestjs/testing": "^10.2.10",
    "vitest": "^0.34.6",
    "@vitest/ui": "^0.34.6",
    "ts-node": "^10.9.2",
    "ts-loader": "^9.5.1",
    "eslint": "^8.54.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
